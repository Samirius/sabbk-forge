          {
            "type": "handoff",
            "from": "pi-marketing"
          },
          {
            "type": "handoff",
            "from": "pi-design"
          },
          {
            "type": "handoff",
            "from": "pi-pm"
          }
        ],
        "produces": [
          {
            "type": "artifact",
            "path": "sabbk-clients/<client>/build/",
            "schema": "build-output"
          },
          {
            "type": "artifact",
            "path": "sabbk-clients/<client>/build/VALIDATION.md",
            "schema": "validation"
          },
          {
            "type": "handoff",
            "to": "pi-pm",
            "must_cite": [
              "playbook",
              "phase"
            ]
          }
        ],
        "checkpoints": [
