{
  "version": 1,
  "_comment": "Agent Roster Manifest \u2014 single source of truth. All agents run via the one `pi` CLI, differentiated by kind/tools/stages. Models: haiku here keeps demos cheap; PRODUCTION swaps managers to a smart (Sonnet/Opus-class) id from `pi --list-models` and keeps grunt stages cheap. Manager pattern (D21): each domain agent is manager-only now; specialist sub-agents are added when a single agent gets overloaded.",
  "agents": [
    {
      "id": "pi-pm",
      "name": "Conductor",
      "tier": 2,
      "kind": "orchestrator",
      "role": "Pi PM (manager-only): take a work request, assign it to the right gear with a Sabbk-compliant handoff, run human checkpoints, and aggregate reporting.",
      "runtime": {
        "harness": "pi-agent-core",
        "pinned_version": "0.78.0"
      },
      "model": {
        "provider": "glm",
        "id": "glm-5.1",
        "thinking": "medium"
      },
      "tools": {
        "assign": [
          "read",
          "write",
          "ls"
        ],
        "report": [
          "read",
          "write",
          "grep",
          "ls"
        ]
      },
      "playbook": "playbooks/software.md",
      "boundaries": [
        "never read shared/personal/ or any restricted/ folder",
        "no client or Banafah work of any kind",
        "AI branches end in -ai; pull before push; never force-push",
        "credentials come only from the environment; never print or commit a secret"
      ],
      "budget": {
        "max_turns": 4,
        "max_usd": 0.25,
        "timeout_sec": 120
      },
      "gear": {
        "consumes": [
          {
            "type": "request",
            "path": "pipeline/REQUEST.md",
            "requires": [
              "objective"
            ]
          }
        ],
        "produces": [
          {
            "type": "handoff",
            "to": "pi-coding-spike",
            "path": "spike/workdir/pi-coding-spike/INBOX-handoff.md",
            "schema": "handoff",
            "must_cite": [
              "playbook",
              "phase"
            ]
          },
          {
            "type": "handoff",
            "to": "pi-software",
            "path": "spike/workdir/pi-software/INBOX-handoff.md",
            "schema": "handoff",
            "must_cite": [
              "playbook",
              "phase"
            ]
          }
        ],
        "checkpoints": [
          {
            "when": "after_assignment_before_dispatch",
            "policy": "AlwaysConfirm",
            "question": "Approve PM's assignment + dispatch to the coding gear?"
          }
        ]
      }
    },
