      "tools": {
        "spec": [
          "read",
          "grep",
          "ls",
          "write"
        ],
        "plan": [
          "read",
          "grep",
          "ls",
          "write"
        ],
        "build": [
          "read",
          "bash",
          "edit",
          "write"
        ],
        "build_lite": [
          "read",
          "edit",
          "write"
        ],
        "validate": [
          "read",
          "bash",
          "grep",
          "ls",
          "write"
        ],
        "validate_lite": [
          "read",
          "grep",
          "ls",
          "write"
        ]
      },
      "playbook": "playbooks/software.md",
      "boundaries": [
        "never read shared/personal/ or any restricted/ folder",
        "work only on the branch/paths in the assignment handoff",
        "every change ships with a SPEC (acceptance criteria) + a VALIDATION (evidence per criterion)",
        "jigs/tests must pass before handing back; keep diffs small and reviewable",
        "enumerate tracked files with git ls-files, never find",
        "cite Playbook + Phase (software/PLAYBOOK.md) in the return handoff",
        "AI branches end in -ai; pull before push; never force-push",
        "credentials come only from the environment; never print or commit a secret"
      ],
      "budget": {
        "max_turns": 10,
        "max_usd": 0.8,
        "timeout_sec": 300
